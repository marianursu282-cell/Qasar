        print(assistant_name + ": Я твой личный ИИ, разработанный под кодовым именем Квазар.")
        
    elif "выход" in command or "стоп" in command or "пока" in command:
        print(assistant_name + ": Связь завершена. До связи, " + user_name + "!")
        break
        
    else:
        print(assistant_name + ": Команда не распознана. Моя база данных пока ограничена, но я учусь! Напишите 'помощь'.")
